{
  "name": "@ground/proto",
  "nx": {
    "name": "proto",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "mkdir -p dist && pnpm exec pbjs -p src src/ground/v1beta1/*.proto -t static-module -o dist/ground-protos.js",
            "mkdir -p dist && pnpm exec pbjs -p src src/ground/v1beta1/*.proto -t json -o dist/ground-protos.json",
            "pnpm exec pbts dist/ground-protos.js -o dist/ground-protos.d.ts",
            "cp src/index.* dist/"
          ],
          "parallel": false
        }
      },
      "clean": {
        "command": "rm -rf dist"
      },
      "lint": {
        "command": "node scripts/lint.js"
      },
      "format:write": {
        "command": "buf format --write"
      }
    }
  },
  "version": "0.0.1",
  "description": "Ground shared Protocol Buffer definitions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "dependencies": {
    "protobufjs": "catalog:"
  },
  "devDependencies": {
    "@bufbuild/buf": "catalog:dev",
    "protobufjs-cli": "catalog:dev"
  }
}
