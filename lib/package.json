{
  "name": "@ground/lib",
  "nx": {
    "name": "lib",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "command": "tsc"
        }
      },
      "clean": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "command": "rm -rf dist *.log src/generated"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "command": "eslint src"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "command": "jasmine --config=jasmine.json"
        }
      },
      "format:check": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "command": "prettier --check \"src/**/*.ts\""
        }
      }
    }
  },
  "version": "0.0.1",
  "main": "dist/index.js",
  "description": "Ground shared lib",
  "exports": {
    ".": "./dist/index.js",
    "./testing/firestore": "./dist/testing/firestore/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "22"
  },
  "private": true,
  "dependencies": {
    "@google-cloud/firestore": "catalog:",
    "@ground/proto": "workspace:*",
    "firebase-admin": "catalog:",
    "firebase-functions": "catalog:",
    "protobufjs": "catalog:"
  },
  "devDependencies": {
    "@types/geojson": "catalog:dev",
    "@types/jasmine": "catalog:dev",
    "@types/source-map-support": "catalog:dev",
    "diff": "catalog:dev",
    "mock-cloud-firestore": "catalog:dev",
    "picocolors": "catalog:dev",
    "source-map-support": "catalog:dev"
  }
}
